    1: from __future__ import annotations
       
    1: import enum
    1: import typing as t
       
       
    2: class Sentinel(enum.Enum):
    1:     """Enum used to define sentinel values.
       
           .. seealso::
       
               `PEP 661 - Sentinel Values <https://peps.python.org/pep-0661/>`_.
           """
       
    1:     UNSET = object()
    1:     FLAG_NEEDS_VALUE = object()
       
    1:     def __repr__(self) -> str:
               return f"{self.__class__.__name__}.{self.name}"
       
       
    1: UNSET = Sentinel.UNSET
    1: """Sentinel used to indicate that a value is not set."""
       
    1: FLAG_NEEDS_VALUE = Sentinel.FLAG_NEEDS_VALUE
    1: """Sentinel used to indicate an option was passed as a flag without a
       value but is not a flag option.
       
       ``Option.consume_value`` uses this to prompt or use the ``flag_value``.
       """
       
    1: T_UNSET = t.Literal[UNSET]  # type: ignore[valid-type]
    1: """Type hint for the :data:`UNSET` sentinel value."""
       
    1: T_FLAG_NEEDS_VALUE = t.Literal[FLAG_NEEDS_VALUE]  # type: ignore[valid-type]
    1: """Type hint for the :data:`FLAG_NEEDS_VALUE` sentinel value."""
