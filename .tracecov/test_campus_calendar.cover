    1:     def test_create_event_rejects_reversed_time_range(self):
    1:         manager = InMemoryCalendarManager()
    2:         result = manager.create_event(
    1:             "user-1",
    1:             _event_payload(start_time="2026-03-05T11:00:00Z", end_time="2026-03-05T10:00:00Z"),
               )
    1:         self.assertFalse(result["success"])
