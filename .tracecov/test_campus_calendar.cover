    1:     def test_find_free_slots_returns_gaps(self):
    1:         manager = InMemoryCalendarManager()
    1:         manager.create_event("user-1", _event_payload(start_time="2026-03-05T09:00:00Z", end_time="2026-03-05T10:00:00Z"))
    1:         manager.create_event("user-1", _event_payload(start_time="2026-03-05T11:00:00Z", end_time="2026-03-05T12:00:00Z"))
       
    2:         free = manager.find_free_slots(
    1:             "user-1",
    1:             start=datetime(2026, 3, 5, 8, 0, tzinfo=timezone.utc),
    1:             end=datetime(2026, 3, 5, 13, 0, tzinfo=timezone.utc),
    1:             min_duration=30,
               )
       
    1:         self.assertTrue(free["success"])
    1:         self.assertEqual(len(free["free_slots"]), 3)
    1:         self.assertTrue(free["free_slots"][0]["start"].startswith("2026-03-05T08:00:00"))
       
    1:     def test_get_statistics_counts_event_types(self):
    1:         manager = InMemoryCalendarManager()
