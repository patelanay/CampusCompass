    2: class InMemoryCalendarManagerTests(unittest.TestCase):
    1:     def test_create_event_requires_all_required_fields(self):
    1:         manager = InMemoryCalendarManager()
    1:         result = manager.create_event("user-1", {"title": "Missing fields"})
    1:         self.assertFalse(result["success"])
