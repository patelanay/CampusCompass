               )
       
    1:         self.assertTrue(stats["success"])
    1:         self.assertEqual(stats["statistics"]["class"], 1)
    1:         self.assertEqual(stats["statistics"]["exam"], 1)
       
    1:     def test_load_user_calendar_check_availability(self):
    1:         manager = InMemoryCalendarManager()
    1:         manager.create_event("user-1", _event_payload(start_time="2026-03-05T09:00:00Z", end_time="2026-03-05T10:00:00Z"))
    1:         calendar = manager.load_user_calendar("user-1")
       
    2:         available = calendar.check_availability(
    1:             datetime(2026, 3, 5, 10, 0, tzinfo=timezone.utc),
    1:             datetime(2026, 3, 5, 11, 0, tzinfo=timezone.utc),
               )
    2:         conflict = calendar.check_availability(
    1:             datetime(2026, 3, 5, 9, 30, tzinfo=timezone.utc),
    1:             datetime(2026, 3, 5, 9, 45, tzinfo=timezone.utc),
               )
       
    1:         self.assertTrue(available)
    1:         self.assertFalse(conflict)
       
       
