    1:     def test_update_event_success_and_missing_event(self):
    1:         manager = InMemoryCalendarManager()
    1:         created = manager.create_event("user-1", _event_payload())
    1:         event_id = created["event_id"]
       
    1:         success = manager.update_event(event_id, "user-1", {"title": "Updated"})
    1:         missing = manager.update_event("missing", "user-1", {"title": "Updated"})
       
    1:         self.assertEqual(success, {"success": True})
    1:         self.assertFalse(missing["success"])
    1:         self.assertEqual(manager.get_event(event_id, "user-1")["title"], "Updated")
       
    1:     def test_delete_event_success_and_failure(self):
    1:         manager = InMemoryCalendarManager()
    1:         created = manager.create_event("user-1", _event_payload())
    1:         event_id = created["event_id"]
       
    1:         self.assertEqual(manager.delete_event(event_id, "user-1"), {"success": True})
    1:         missing = manager.delete_event(event_id, "user-1")
