    1:     def test_create_event_success_and_get_event(self):
    1:         manager = InMemoryCalendarManager()
    1:         result = manager.create_event("user-1", _event_payload())
    1:         self.assertTrue(result["success"])
       
    1:         event = manager.get_event(result["event_id"], "user-1")
    1:         self.assertIsNotNone(event)
    1:         self.assertEqual(event["title"], "Algorithms Lecture")
    1:         self.assertEqual(event["event_type"], "class")
       
    1:     def test_create_event_detects_time_conflict(self):
    1:         manager = InMemoryCalendarManager()
    1:         first = manager.create_event("user-1", _event_payload())
    1:         self.assertTrue(first["success"])
       
    2:         second = manager.create_event(
    1:             "user-1",
    1:             _event_payload(start_time="2026-03-05T09:30:00Z", end_time="2026-03-05T10:30:00Z"),
               )
    1:         self.assertFalse(second["success"])
    1:         self.assertIn("conflicts", second["error"])
       
    1:     def test_get_user_events_honors_date_filter(self):
    1:         manager = InMemoryCalendarManager()
    2:         manager.create_event(
    1:             "user-1",
    1:             _event_payload(title="Morning", start_time="2026-03-05T09:00:00Z", end_time="2026-03-05T10:00:00Z"),
               )
    2:         manager.create_event(
    1:             "user-1",
    1:             _event_payload(title="Noon", start_time="2026-03-05T12:00:00Z", end_time="2026-03-05T13:00:00Z"),
               )
       
    2:         filtered = manager.get_user_events(
    1:             "user-1",
    1:             start=datetime(2026, 3, 5, 10, 30, tzinfo=timezone.utc),
    1:             end=datetime(2026, 3, 5, 13, 0, tzinfo=timezone.utc),
               )
       
    1:         self.assertEqual(len(filtered), 1)
