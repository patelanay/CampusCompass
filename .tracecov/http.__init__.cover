    3: @_simple_enum(IntEnum)
    2: class HTTPStatus:
    1:     """HTTP status codes and reason phrases
       
           Status codes from the following RFCs are all observed:
       
               * RFC 9110: HTTP Semantics, obsoletes 7231, which obsoleted 2616
               * RFC 6585: Additional HTTP Status Codes
               * RFC 3229: Delta encoding in HTTP
               * RFC 4918: HTTP Extensions for WebDAV, obsoletes 2518
               * RFC 5842: Binding Extensions to WebDAV
               * RFC 7238: Permanent Redirect
               * RFC 2295: Transparent Content Negotiation in HTTP
               * RFC 2774: An HTTP Extension Framework
               * RFC 7725: An HTTP Status Code to Report Legal Obstacles
               * RFC 7540: Hypertext Transfer Protocol Version 2 (HTTP/2)
               * RFC 2324: Hyper Text Coffee Pot Control Protocol (HTCPCP/1.0)
               * RFC 8297: An HTTP Status Code for Indicating Hints
               * RFC 8470: Using Early Data in HTTP
           """
    1:     def __new__(cls, value, phrase, description=''):
   66:         obj = int.__new__(cls, value)
   66:         obj._value_ = value
   66:         obj.phrase = phrase
   66:         obj.description = description
   66:         return obj
       
    2:     @property
    2:     def is_informational(self):
               return 100 <= self <= 199
       
    2:     @property
    2:     def is_success(self):
               return 200 <= self <= 299
       
    2:     @property
    2:     def is_redirection(self):
               return 300 <= self <= 399
       
    2:     @property
    2:     def is_client_error(self):
               return 400 <= self <= 499
       
    2:     @property
    2:     def is_server_error(self):
               return 500 <= self <= 599
       
           # informational
    1:     CONTINUE = 100, 'Continue', 'Request received, please continue'
    1:     SWITCHING_PROTOCOLS = (101, 'Switching Protocols',
                   'Switching to new protocol; obey Upgrade header')
    1:     PROCESSING = 102, 'Processing', 'Server is processing the request'
    1:     EARLY_HINTS = (103, 'Early Hints',
                   'Headers sent to prepare for the response')
       
           # success
    1:     OK = 200, 'OK', 'Request fulfilled, document follows'
    1:     CREATED = 201, 'Created', 'Document created, URL follows'
    1:     ACCEPTED = (202, 'Accepted',
               'Request accepted, processing continues off-line')
    1:     NON_AUTHORITATIVE_INFORMATION = (203,
               'Non-Authoritative Information', 'Request fulfilled from cache')
    1:     NO_CONTENT = 204, 'No Content', 'Request fulfilled, nothing follows'
    1:     RESET_CONTENT = 205, 'Reset Content', 'Clear input form for further input'
    1:     PARTIAL_CONTENT = 206, 'Partial Content', 'Partial content follows'
    1:     MULTI_STATUS = (207, 'Multi-Status',
               'Response contains multiple statuses in the body')
    1:     ALREADY_REPORTED = (208, 'Already Reported',
               'Operation has already been reported')
    1:     IM_USED = 226, 'IM Used', 'Request completed using instance manipulations'
       
           # redirection
    1:     MULTIPLE_CHOICES = (300, 'Multiple Choices',
               'Object has several resources -- see URI list')
    1:     MOVED_PERMANENTLY = (301, 'Moved Permanently',
               'Object moved permanently -- see URI list')
    1:     FOUND = 302, 'Found', 'Object moved temporarily -- see URI list'
    1:     SEE_OTHER = 303, 'See Other', 'Object moved -- see Method and URL list'
    1:     NOT_MODIFIED = (304, 'Not Modified',
