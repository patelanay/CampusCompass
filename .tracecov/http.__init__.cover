    3: @_simple_enum(StrEnum)
    2: class HTTPMethod:
    1:     """HTTP methods and descriptions
       
           Methods from the following RFCs are all observed:
       
               * RFC 9110: HTTP Semantics, obsoletes 7231, which obsoleted 2616
               * RFC 5789: PATCH Method for HTTP
           """
    1:     def __new__(cls, value, description):
    9:         obj = str.__new__(cls, value)
    9:         obj._value_ = value
    9:         obj.description = description
    9:         return obj
       
    1:     def __repr__(self):
               return "<%s.%s>" % (self.__class__.__name__, self._name_)
       
    1:     CONNECT = 'CONNECT', 'Establish a connection to the server.'
    1:     DELETE = 'DELETE', 'Remove the target.'
    1:     GET = 'GET', 'Retrieve the target.'
    1:     HEAD = 'HEAD', 'Same as GET, but only retrieve the status line and header section.'
    1:     OPTIONS = 'OPTIONS', 'Describe the communication options for the target.'
    1:     PATCH = 'PATCH', 'Apply partial modifications to a target.'
    1:     POST = 'POST', 'Perform target-specific processing with the request payload.'
    1:     PUT = 'PUT', 'Replace the target with the request payload.'
    1:     TRACE = 'TRACE', 'Perform a message loop-back test along the path to the target.'
