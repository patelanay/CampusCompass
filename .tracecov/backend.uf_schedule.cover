    1: def process_ics_file(file_path):
    6:     with open(file_path, 'r', encoding='utf-8') as file:
    3:         content = file.read()
       
    3:     calendar = Calendar(content)
    3:     results = []
       
    6:     for event in calendar.events:
    3:         location = event.location if event.location else ""
    3:         code = location[:3].upper()
    3:         url = building_code_to_url.get(code, "No URL found for this location code")
       
    3:         event_info = {
    3:             "event": event.name,
    3:             "location_code": code,
    3:             "location_url": url
               }
    3:         results.append(event_info)
       
    3:     return results
       
