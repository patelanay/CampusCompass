               >>> ep.matches(group='foo')
               True
               >>> ep.matches(name='bar', value='bing:bong [extra1, extra2]')
               True
               >>> ep.matches(group='foo', name='other')
               False
               >>> ep.matches()
               True
               >>> ep.matches(extras=['extra1', 'extra2'])
               True
               >>> ep.matches(module='bing')
               True
               >>> ep.matches(attr='bong')
               True
