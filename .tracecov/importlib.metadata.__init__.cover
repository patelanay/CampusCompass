           >>> item = next(res)
           >>> item.name
           'sec1'
           >>> item.value
           Pair(name='a', value='1')
           >>> item = next(res)
           >>> item.value
           Pair(name='b', value='2')
           >>> item = next(res)
           >>> item.name
           'sec2'
           >>> item.value
