    5:             "order_default": order_default,
    5:             "kw_only_default": kw_only_default,
    5:             "frozen_default": frozen_default,
    5:             "field_specifiers": field_specifiers,
    5:             "kwargs": kwargs,
               }
    5:         return cls_or_fn
    5:     return decorator
       
       
