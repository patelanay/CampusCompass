    1:     eq_default: bool = True,
    1:     order_default: bool = False,
    1:     kw_only_default: bool = False,
    1:     frozen_default: bool = False,
    1:     field_specifiers: tuple[type[Any] | Callable[..., Any], ...] = (),
           **kwargs: Any,
