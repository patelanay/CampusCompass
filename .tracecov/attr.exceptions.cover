    1: from __future__ import annotations
       
    1: from typing import ClassVar
       
       
    2: class FrozenError(AttributeError):
    1:     """
           A frozen/immutable instance or attribute have been attempted to be
           modified.
       
           It mirrors the behavior of ``namedtuples`` by using the same error message
           and subclassing `AttributeError`.
       
           .. versionadded:: 20.1.0
           """
       
    1:     msg = "can't set attribute"
    1:     args: ClassVar[tuple[str]] = [msg]
       
       
    2: class FrozenInstanceError(FrozenError):
    1:     """
           A frozen instance has been attempted to be modified.
       
           .. versionadded:: 16.1.0
           """
       
       
    2: class FrozenAttributeError(FrozenError):
    1:     """
           A frozen attribute has been attempted to be modified.
       
           .. versionadded:: 20.1.0
           """
       
       
    2: class AttrsAttributeNotFoundError(ValueError):
    1:     """
           An *attrs* function couldn't find an attribute that the user asked for.
       
           .. versionadded:: 16.2.0
           """
       
       
    2: class NotAnAttrsClassError(ValueError):
    1:     """
           A non-*attrs* class has been passed into an *attrs* function.
       
           .. versionadded:: 16.2.0
           """
       
       
    2: class DefaultAlreadySetError(RuntimeError):
    1:     """
           A default has been set when defining the field and is attempted to be reset
           using the decorator.
       
           .. versionadded:: 17.1.0
           """
       
       
    2: class UnannotatedAttributeError(RuntimeError):
    1:     """
           A class with ``auto_attribs=True`` has a field without a type annotation.
       
           .. versionadded:: 17.3.0
           """
       
       
    2: class PythonTooOldError(RuntimeError):
    1:     """
           It was attempted to use an *attrs* feature that requires a newer Python
           version.
       
           .. versionadded:: 18.2.0
           """
       
       
    2: class NotCallableError(TypeError):
    1:     """
           A field requiring a callable has been set with a value that is not
           callable.
       
           .. versionadded:: 19.2.0
           """
       
    1:     def __init__(self, msg, value):
               super(TypeError, self).__init__(msg, value)
               self.msg = msg
               self.value = value
       
    1:     def __str__(self):
               return str(self.msg)
