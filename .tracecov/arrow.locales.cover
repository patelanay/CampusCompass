    1:     def _ordinal_number(self, n: int) -> str:
               if n > 10 or n == 0:
                   return f"{n}ତମ"
               if n in [1, 5, 7, 8, 9, 10]:
                   return f"{n}ମ"
               if n in [2, 3]:
                   return f"{n}ୟ"
               if n == 4:
                   return f"{n}ର୍ଥ"
               if n == 6:
                   return f"{n}ଷ୍ଠ"
               return ""
       
       
