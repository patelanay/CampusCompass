    1:     def _format_timeframe(self, timeframe: TimeFrameLiteral, delta: int) -> str:
               form = self.timeframes[timeframe]
               delta = abs(delta)
               if isinstance(form, Mapping):
                   if 1 < delta <= 4:
                       form = form["double"]
                   else:
                       form = form["higher"]
       
               return form.format(delta)
       
       
