    3: class GermanBaseLocale(Locale):
    1:     past = "vor {0}"
    1:     future = "in {0}"
    1:     and_word = "und"
       
    1:     timeframes: ClassVar[Dict[TimeFrameLiteral, str]] = {
    1:         "now": "gerade eben",
    1:         "second": "einer Sekunde",
    1:         "seconds": "{0} Sekunden",
    1:         "minute": "einer Minute",
    1:         "minutes": "{0} Minuten",
    1:         "hour": "einer Stunde",
    1:         "hours": "{0} Stunden",
    1:         "day": "einem Tag",
    1:         "days": "{0} Tagen",
    1:         "week": "einer Woche",
    1:         "weeks": "{0} Wochen",
    1:         "month": "einem Monat",
    1:         "months": "{0} Monaten",
    1:         "year": "einem Jahr",
    1:         "years": "{0} Jahren",
           }
       
    1:     timeframes_only_distance = timeframes.copy()
    1:     timeframes_only_distance["second"] = "eine Sekunde"
    1:     timeframes_only_distance["minute"] = "eine Minute"
    1:     timeframes_only_distance["hour"] = "eine Stunde"
    1:     timeframes_only_distance["day"] = "ein Tag"
    1:     timeframes_only_distance["days"] = "{0} Tage"
    1:     timeframes_only_distance["week"] = "eine Woche"
    1:     timeframes_only_distance["month"] = "ein Monat"
    1:     timeframes_only_distance["months"] = "{0} Monate"
    1:     timeframes_only_distance["year"] = "ein Jahr"
    1:     timeframes_only_distance["years"] = "{0} Jahre"
       
    1:     month_names = [
               "",
               "Januar",
               "Februar",
               "März",
               "April",
               "Mai",
               "Juni",
               "Juli",
               "August",
               "September",
               "Oktober",
               "November",
               "Dezember",
           ]
       
    1:     month_abbreviations = [
               "",
               "Jan",
               "Feb",
               "Mär",
               "Apr",
               "Mai",
               "Jun",
               "Jul",
               "Aug",
               "Sep",
               "Okt",
               "Nov",
               "Dez",
           ]
       
    1:     day_names = [
               "",
               "Montag",
               "Dienstag",
               "Mittwoch",
               "Donnerstag",
               "Freitag",
               "Samstag",
               "Sonntag",
           ]
       
    1:     day_abbreviations = ["", "Mo", "Di", "Mi", "Do", "Fr", "Sa", "So"]
       
    1:     def _ordinal_number(self, n: int) -> str:
               return f"{n}."
       
    1:     def describe(
               self,
               timeframe: TimeFrameLiteral,
               delta: Union[int, float] = 0,
               only_distance: bool = False,
           ) -> str:
               """Describes a delta within a timeframe in plain language.
       
               :param timeframe: a string representing a timeframe.
               :param delta: a quantity representing a delta in a timeframe.
               :param only_distance: return only distance eg: "11 seconds" without "in" or "ago" keywords
               """
       
               if not only_distance:
                   return super().describe(timeframe, delta, only_distance)
       
               # German uses a different case without 'in' or 'ago'
               humanized: str = self.timeframes_only_distance[timeframe].format(
                   trunc(abs(delta))
               )
       
               return humanized
       
       
