    1: def lines_to_container(lines, linewise=True):
    3:     if linewise:
    3:         return parse(tokenize_line(unfold_lines(lines, with_linenr=True)))  # linewise
           else:
               return string_to_container("\r\n".join(lines), linewise)  # full-string
       
       
    1: def string_to_container(txt, linewise=True):
    3:     if linewise:
    3:         return lines_to_container(txt.split("\n"), linewise)  # linewise
           else:
               return parse(string_to_content_lines(txt))  # full-string
       
       
    1: def string_to_content_lines(txt):
           txt = re.sub("\r?\n[ \t]", "", txt)
           ast = GRAMMAR.parse(txt, rule_name='full')
           for line in ast:
               line = line[0]
               name = ''.join(line['name'])
               value = ''.join(line['value'])
               params = {}
               for param_ast in line.get('params', []):
                   param_name = ''.join(param_ast["name"])
                   param_values = [''.join(x["value"]) for x in param_ast["values"]]
                   params[param_name] = param_values
               yield ContentLine(name, params, value)
       
       
    1: def calendar_string_to_containers(string):
    3:     if not isinstance(string, str):
               raise TypeError("Expecting a string")
    3:     return string_to_container(string)
