    2: class Container(list):
    1:     """Represents an iCalendar object.
           Contains a list of ContentLines or Containers.
       
           Args:
       
               name: the name of the object (VCALENDAR, VEVENT etc.)
               items: Containers or ContentLines
           """
       
    1:     def __init__(self, name: str, *items: List):
   12:         super(Container, self).__init__(items)
   12:         self.name = name
       
    1:     def __str__(self):
               name = self.name
               ret = ['BEGIN:' + name]
               for line in self:
                   ret.append(str(line))
               ret.append('END:' + name)
               return "\r\n".join(ret)
       
    1:     def __repr__(self):
               return "<Container '{}' with {} element{}>" \
                   .format(self.name, len(self), "s" if len(self) > 1 else "")
       
    2:     @classmethod
    2:     def parse(cls, name, tokenized_lines):
    6:         items = []
   27:         for line in tokenized_lines:
   27:             if line.name == 'BEGIN':
    3:                 items.append(Container.parse(line.value, tokenized_lines))
   24:             elif line.name == 'END':
    6:                 if line.value != name:
                           raise ParseError(
                               "Expected END:{}, got END:{}".format(name, line.value))
    6:                 break
                   else:
   18:                 items.append(line)
    6:         return cls(name, *items)
       
    1:     def clone(self):
               """Makes a copy of itself"""
               c = self.__class__(self.name)
               for elem in self:
                   c.append(elem.clone())
               return c
       
       
    1: def unfold_lines(physical_lines, with_linenr=False):
    3:     if not isinstance(physical_lines, collections.abc.Iterable):
               raise ParseError('Parameter `physical_lines` must be an iterable')
    3:     current_nr = -1
    3:     current_line = ''
   36:     for nr, line in enumerate(physical_lines):
   33:         if len(line.strip()) == 0:
    3:             continue
   30:         elif not current_line:
    3:             current_nr = nr
    3:             current_line = line.strip('\r')
   27:         elif line[0] in (' ', '\t'):
                   current_line += line[1:].strip('\r')
               else:
   27:             if with_linenr:
   27:                 yield current_nr, current_line
                   else:
                       yield current_line
   27:             current_nr = nr
   27:             current_line = line.strip('\r')
    3:     if current_line:
    3:         if with_linenr:
    3:             yield current_nr, current_line
               else:
                   yield current_line
       
       
    1: def tokenize_line(unfolded_lines):
   33:     for line in unfolded_lines:
   30:         if isinstance(line, tuple):
   30:             yield ContentLine.parse(line[1], line[0])
               else:
                   yield ContentLine.parse(line)
       
       
    1: def parse(tokenized_lines, block_name=None):
    3:     res = []
    6:     for line in tokenized_lines:
    3:         if line.name == 'BEGIN':
    3:             res.append(Container.parse(line.value, tokenized_lines))
               else:
                   res.append(line)
