    1:     undefined = object()
       
    2:     @functools.wraps(func)
    2:     def wrapper(anchor=undefined, package=undefined):
    1:         if package is not undefined:
                   if anchor is not undefined:
                       return func(anchor, package)
                   warnings.warn(
                       "First parameter to files is renamed to 'anchor'",
                       DeprecationWarning,
                       stacklevel=2,
                   )
                   return func(package)
    1:         elif anchor is undefined:
                   return func()
    1:         return func(anchor)
       
    1:     return wrapper
       
       
    2: @package_to_anchor
