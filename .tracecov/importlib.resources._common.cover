    1: def get_resource_reader(package: types.ModuleType) -> Optional[ResourceReader]:
           """
           Return the package's loader if it's a ResourceReader.
           """
           # We can't use
           # a issubclass() check here because apparently abc.'s __subclasscheck__()
           # hook wants to create a weak reference to the object, but
           # zipimport.zipimporter does not support weak references, resulting in a
           # TypeError.  That seems terrible.
           spec = package.__spec__
           reader = getattr(spec.loader, 'get_resource_reader', None)  # type: ignore[union-attr]
           if reader is None:
               return None
           return reader(spec.name)  # type: ignore[union-attr]
       
       
    2: @functools.singledispatch
    2: def resolve(cand: Optional[Anchor]) -> types.ModuleType:
           return cast(types.ModuleType, cand)
       
       
    2: @resolve.register
    3: def _(cand: str) -> types.ModuleType:
    1:     return importlib.import_module(cand)
       
       
    2: @resolve.register
    3: def _(cand: None) -> types.ModuleType:
