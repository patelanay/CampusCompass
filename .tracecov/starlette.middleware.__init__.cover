    1: from __future__ import annotations
       
    1: from collections.abc import Awaitable, Callable, Iterator
    1: from typing import Any, ParamSpec, Protocol
       
    1: P = ParamSpec("P")
       
       
    1: _Scope = Any
    1: _Receive = Callable[[], Awaitable[Any]]
    1: _Send = Callable[[Any], Awaitable[None]]
       # Since `starlette.types.ASGIApp` type differs from `ASGIApplication` from `asgiref`
       # we need to define a more permissive version of ASGIApp that doesn't cause type errors.
    1: _ASGIApp = Callable[[_Scope, _Receive, _Send], Awaitable[None]]
       
       
    2: class _MiddlewareFactory(Protocol[P]):
    1:     def __call__(self, app: _ASGIApp, /, *args: P.args, **kwargs: P.kwargs) -> _ASGIApp: ...  # pragma: no cover
       
       
    2: class Middleware:
    1:     def __init__(self, cls: _MiddlewareFactory[P], *args: P.args, **kwargs: P.kwargs) -> None:
    1:         self.cls = cls
    1:         self.args = args
    1:         self.kwargs = kwargs
       
    1:     def __iter__(self) -> Iterator[Any]:
               as_tuple = (self.cls, self.args, self.kwargs)
               return iter(as_tuple)
       
    1:     def __repr__(self) -> str:
               class_name = self.__class__.__name__
               args_strings = [f"{value!r}" for value in self.args]
               option_strings = [f"{key}={value!r}" for key, value in self.kwargs.items()]
               name = getattr(self.cls, "__name__", "")
               args_repr = ", ".join([name] + args_strings + option_strings)
               return f"{class_name}({args_repr})"
