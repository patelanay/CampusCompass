    2: IANA_SUPPORTED: list[str] = sorted(
    2:     filter(
  211:         lambda x: x.endswith("_codec") is False
  102:         and x not in {"rot_13", "tactis", "mbcs"},
    1:         list(set(aliases.values())) + IANA_NO_ALIASES,
           )
       )
       
    1: IANA_SUPPORTED_COUNT: int = len(IANA_SUPPORTED)
       
