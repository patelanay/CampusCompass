    2: RE_POSSIBLE_ENCODING_INDICATION = re_compile(
    1:     r"(?:(?:encoding)|(?:charset)|(?:coding))(?:[\:= ]{1,10})(?:[\"\']?)([a-zA-Z0-9\-_]+)(?:[\"\']?)",
    1:     IGNORECASE,
       )
       
