                       if d is None:
                           raise errors.UrlHostError()
                       is_international = True
       
                   tld = d.group('tld')
                   if tld is None and not is_international:
                       d = int_domain_regex().fullmatch(host)
                       assert d is not None
                       tld = d.group('tld')
                       is_international = True
       
                   if tld is not None:
                       tld = tld[1:]
                   elif cls.tld_required:
                       raise errors.UrlHostTldError()
       
                   if is_international:
