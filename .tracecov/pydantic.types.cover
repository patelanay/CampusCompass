    1:     byte_string_re = re.compile(byte_string_pattern, re.IGNORECASE)
       
    2:     @classmethod
    2:     def __get_pydantic_core_schema__(cls, source: type[Any], handler: GetCoreSchemaHandler) -> core_schema.CoreSchema:
