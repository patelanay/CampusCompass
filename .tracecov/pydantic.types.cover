           print(model)
           #> password=SecretStr('**********') password_bytes=SecretBytes(b'**********')
           print(model.password)
           #> **********
           print(model.model_dump())
           '''
           {
               'password': SecretStr('**********'),
               'password_bytes': SecretBytes(b'**********'),
           }
           '''
           print(model.model_dump_json())
           #> {"password":"IAmSensitive","password_bytes":"IAmSensitiveBytes"}
           ```
