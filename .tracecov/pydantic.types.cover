               class ImportThings(BaseModel):
                   obj: ImportString
       
               # Create an instance
               m = ImportThings(obj='math.cos')
               print(m)
               #> obj=<built-in function cos>
               print(m.model_dump_json())
               #> {"obj":"math.cos"}
               ```
               """
       
