           print(repr(Model.model_validate_json(json.dumps(valid_json_data))))
           #> Model(j={'a': {'b': {'c': 1, 'd': [2, None]}}})
       
           try:
               Model.model_validate(invalid_json_data)
           except ValidationError as e:
               print(e)
