    1:     if callable(name):
               func = name
               name = None
               assert cls is None, "Use 'command(cls=cls)(callable)' to specify a class."
               assert not attrs, "Use 'command(**kwargs)(callable)' to provide arguments."
       
    1:     if cls is None:
    1:         cls = t.cast("type[CmdType]", Command)
       
    1:     def decorator(f: _AnyCallable) -> CmdType:
    1:         if isinstance(f, Command):
                   raise TypeError("Attempted to convert a callback into a command twice.")
       
    1:         attr_params = attrs.pop("params", None)
    1:         params = attr_params if attr_params is not None else []
       
