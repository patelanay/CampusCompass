    1:             decorator_params = f.__click_params__  # type: ignore
               except AttributeError:
                   pass
               else:
    1:             del f.__click_params__  # type: ignore
    1:             params.extend(reversed(decorator_params))
       
    1:         if attrs.get("help") is None:
    1:             attrs["help"] = f.__doc__
       
    1:         if t.TYPE_CHECKING:
                   assert cls is not None
                   assert not callable(name)
       
    1:         if name is not None:
                   cmd_name = name
               else:
    1:             cmd_name = f.__name__.lower().replace("_", "-")
    1:             cmd_left, sep, suffix = cmd_name.rpartition("-")
       
    1:             if sep and suffix in {"command", "cmd", "group", "grp"}:
                       cmd_name = cmd_left
       
    1:         cmd = cls(name=cmd_name, callback=f, params=params, **attrs)
    1:         cmd.__doc__ = f.__doc__
    1:         return cmd
       
    1:     if func is not None:
               return decorator(func)
       
    1:     return decorator
       
       
